# BasePulse trust-score API — defaults to your live Render deployment.
# Only override this if you're pointing at a local dev instance.
BASEPULSE_API_URL=https://basepulse-trust.onrender.com

# Note: Render free tier cold-starts after idle. The client retries up to
# 4 times, 8s apart, before falling back to "flag for review" — same
# pattern as your frontend's useTrustScore.js hook. If demoing live, hit
# /score/:address once ~30s before your demo to warm it up.

# Decision thresholds (0-100 trust score scale — adjust to match your BasePulse scoring range)
THRESHOLD_BLOCK=30
THRESHOLD_FLAG=65

# CDP SDK credentials (from Coinbase Developer Platform)
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=
CDP_NETWORK_ID=base-sepolia

# Set to "true" to use a fake deterministic scorer instead of the live
# BasePulse API above. Leave "false" now that BasePulse is fixed and live.
MOCK_MODE=false

# Independent from MOCK_MODE. Controls whether "approve" decisions actually
# execute via a real CDP wallet, or just simulate/log. Leave "true" (or
# unset) until executeReal() in src/cdpWallet.js is wired to a real wallet —
# otherwise "approve" decisions will 500, since there's nothing real to execute yet.
WALLET_MOCK_MODE=true

PORT=4021
